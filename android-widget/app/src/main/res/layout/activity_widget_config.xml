<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/widget_location_title"
        android:textColor="@color/widget_text"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/config_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/widget_location_body"
        android:textColor="@color/widget_muted"
        android:textSize="16sp" />

    <Button
        android:id="@+id/use_current_location"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="28dp"
        android:text="@string/use_current_location"
        android:textAllCaps="false" />

    <Button
        android:id="@+id/use_tokyo"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:text="@string/use_tokyo"
        android:textAllCaps="false" />
</LinearLayout>
