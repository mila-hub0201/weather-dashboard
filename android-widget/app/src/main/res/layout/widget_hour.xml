<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/hour_card"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:layout_marginHorizontal="2dp"
    android:background="@drawable/hour_background_cloudy"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingHorizontal="2dp"
    android:paddingVertical="3dp">

    <TextView
        android:id="@+id/hour_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="@string/widget_placeholder_time"
        android:textColor="@color/widget_muted"
        android:textSize="11sp" />

    <ImageView
        android:id="@+id/hour_icon"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginVertical="1dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_weather_clear_day" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/hour_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="@string/widget_placeholder_temperature"
            android:textColor="@color/widget_text"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="11dp"
            android:layout_height="11dp"
            android:layout_marginStart="5dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_precipitation" />

        <TextView
            android:id="@+id/hour_pop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="1dp"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="@string/widget_placeholder_pop"
            android:textColor="@color/widget_blue"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
